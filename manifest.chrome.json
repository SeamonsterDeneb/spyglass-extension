{
  "manifest_version": 3,
  "action": {
    "default_icon": "icon-128.png",
    "default_title": "Spyglass"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://seamonsterstudios.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icon-128.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
