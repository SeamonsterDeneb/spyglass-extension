{
  "name": "Spyglass",
  "version": "1.0.0",
  "description": "A tool for checking and fixing color contrast on web pages",
  "homepage_url": "https://seamonsterstudios.com/accessibility/spyglass-contrast-checker/",
  "permissions": [
    "activeTab",
    "<all_urls>"
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "manifest_version": 2,
  "browser_action": {
    "default_icon": "icon-128.png",
    "default_title": "Spyglass"
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "web_accessible_resources": [
    "icon-128.png"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "spyglass@seamonsterstudios.com",
      "strict_min_version": "109.0"
    }
  },
  "data_collection_permissions": {
    "required": [],
    "optional": []
  }
}